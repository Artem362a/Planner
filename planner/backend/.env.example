DATABASE_URL=postgresql://dayplan_user:your_password@localhost:5432/dayplan
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=your_email@gmail.com
FRONTEND_URL=https://your-domain.com
SECRET_KEY=your_secret_key_here
# Telegram-бот (и алерты мониторинга через него же)
TELEGRAM_BOT_TOKEN=123456:your_bot_token
# chat_id, куда Alertmanager шлёт алерты (свой ID можно узнать у @userinfobot)
TELEGRAM_ALERT_CHAT_ID=
# SOCKS-прокси для Telegram API (в RU без него не работает), например
# socks5h://127.0.0.1:10808. Пусто — ходить напрямую.
TELEGRAM_PROXY=
# Формат логов: json (прод, парсится Loki) или console (локальная разработка)
LOG_FORMAT=console
