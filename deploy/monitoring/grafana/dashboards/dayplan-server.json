{
  "uid": "dayplan-server",
  "title": "DayPlan Server",
  "schemaVersion": 39,
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "CPU, %",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100, "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])))",
          "legendFormat": "cpu"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Память, %",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100, "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)",
          "legendFormat": "used"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Диск (корень), %",
      "gridPos": { "h": 9, "w": 8, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100, "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (1 - node_filesystem_avail_bytes{mountpoint=\"/\", fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{mountpoint=\"/\", fstype!~\"tmpfs|overlay\"})",
          "legendFormat": "used"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Load average",
      "gridPos": { "h": 9, "w": 8, "x": 8, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "node_load1", "legendFormat": "1m" },
        { "refId": "B", "expr": "node_load5", "legendFormat": "5m" },
        { "refId": "C", "expr": "node_load15", "legendFormat": "15m" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Сеть",
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(node_network_receive_bytes_total{device!~\"lo|veth.*|br-.*|docker.*\"}[5m]))",
          "legendFormat": "rx"
        },
        {
          "refId": "B",
          "expr": "sum(rate(node_network_transmit_bytes_total{device!~\"lo|veth.*|br-.*|docker.*\"}[5m]))",
          "legendFormat": "tx"
        }
      ]
    }
  ]
}
