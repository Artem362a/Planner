# Used by docker-compose.yml for the postgres service.
# App secrets (SMTP, SECRET_KEY, TELEGRAM_BOT_TOKEN, ...) live in
# planner/backend/.env — see planner/backend/.env.example for those.
POSTGRES_USER=dayplan_user
POSTGRES_PASSWORD=change_me
POSTGRES_DB=dayplan
# Optional: host port for the postgres container, if 5432 is already taken
# by another local Postgres install. Defaults to 5432.
# POSTGRES_HOST_PORT=5433
# Server timezone — the app stores naive local datetimes (reminders!), so
# containers must run in the same TZ as the host used to.
TZ=Europe/Samara
# Grafana admin password (login: admin). Default "admin" is fine locally,
# on the server set a real one.
GRAFANA_ADMIN_PASSWORD=admin
